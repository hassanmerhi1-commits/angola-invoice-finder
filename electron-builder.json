{
  "$schema": "https://raw.githubusercontent.com/electron-userland/electron-builder/master/packages/app-builder-lib/scheme.json",
  "appId": "com.kwanza.erp",
  "productName": "Kwanza ERP",
  "copyright": "Copyright © 2024 Kwanza ERP",
  "directories": {
    "output": "release",
    "buildResources": "build"
  },
  "files": [
    "dist/**/*",
    "electron/**/*",
    "node_modules/**/*",
    "package.json"
  ],
  "asarUnpack": [
    "node_modules/better-sqlite3/**/*"
  ],
  "extraResources": [
    {
      "from": "backend",
      "to": "backend",
      "filter": ["**/*", "!node_modules/**/*"]
    },
    {
      "from": "public/splash.png",
      "to": "splash.png"
    },
    {
      "from": "electron/splash.html",
      "to": "splash.html"
    }
  ],
  "publish": {
    "provider": "github",
    "owner": "hassanmerhi1-commits",
    "repo": "angola-invoice-finder",
    "releaseType": "release"
  },
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": ["x64"]
      },
      {
        "target": "portable",
        "arch": ["x64"]
      }
    ],
    "icon": "build/icon.ico",
    "artifactName": "KwanzaERP-${version}-${arch}.${ext}"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "Kwanza ERP"
  },
  "portable": {
    "artifactName": "KwanzaERP-Portable-${version}.${ext}"
  },
  "mac": {
    "target": ["dmg", "zip"],
    "icon": "build/icon.icns",
    "category": "public.app-category.business",
    "artifactName": "KwanzaERP-${version}-${arch}.${ext}"
  },
  "linux": {
    "target": ["AppImage", "deb"],
    "icon": "build/icon.png",
    "category": "Office",
    "artifactName": "KwanzaERP-${version}-${arch}.${ext}"
  }
}
